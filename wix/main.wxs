<?xml version='1.0' encoding='windows-1252'?>
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'
     xmlns:util='http://schemas.microsoft.com/wix/UtilExtension'>

    <Product
        Id='*'
        Name='bloom'
        UpgradeCode='E1373C7B-6230-408E-B325-066F02C6D249'
        Manufacturer='Marco Todorov'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Manufacturer='Marco Todorov'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'/>

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes'/>

        <Icon Id='ProductICO' SourceFile='assets\logo\bloom.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO'/>
        <Property Id='ARPCOMMENTS' Value='A hardware accelerated image viewer'/>
        <Property Id='ARPURLINFOABOUT' Value='https://github.com/nnmarcoo/bloom'/>
        <Property Id='ARPHELPLINK' Value='https://github.com/nnmarcoo/bloom/issues'/>

        <Property Id='LAUNCHAPP' Value='1'/>
        <Property Id='WIXUI_INSTALLDIR' Value='APPLICATIONFOLDER'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='Program Files'>
                <Directory Id='APPLICATIONFOLDER' Name='bloom'>
                    <Directory Id='Bin' Name='bin'>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='bloom.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\bloom.exe'
                                KeyPath='yes'/>
                        </Component>

                        <Component Id='Path' Guid='126F8F36-3676-4BEF-AA9D-ED3F67740684' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>

                        <!-- ProgID handler â€” always installed, shared by all association groups -->
                        <Component Id='AssocHandler' Guid='*'>
                            <RegistryValue Id='regAssocHandler'      Root='HKLM' Key='Software\Classes\bloom.AssocFile'                               Type='string' Value='Image file'          KeyPath='yes'/>
                            <RegistryValue Id='regAssocFriendlyName' Root='HKLM' Key='Software\Classes\bloom.AssocFile'                               Type='string' Name='FriendlyTypeName' Value='bloom Image File'/>
                            <RegistryValue Id='regAssocIcon'         Root='HKLM' Key='Software\Classes\bloom.AssocFile\DefaultIcon'                   Type='string' Value='"[Bin]bloom.exe",0'/>
                            <RegistryValue Id='regAssocCmd'          Root='HKLM' Key='Software\Classes\bloom.AssocFile\shell\open\command'            Type='string' Value='"[Bin]bloom.exe" "%1"'/>
                        </Component>

                        <!-- Registers bloom in "Default apps" / "Choose default apps by file type" -->
                        <Component Id='AppCapabilities' Guid='*'>
                            <RegistryValue Id='regRegisteredApp'     Root='HKLM' Key='Software\RegisteredApplications'                                Name='bloom' Value='Software\bloom\Capabilities' Type='string' KeyPath='yes'/>
                            <RegistryValue Id='regCapAppName'        Root='HKLM' Key='Software\bloom\Capabilities'                                    Name='ApplicationName'        Type='string' Value='bloom'/>
                            <RegistryValue Id='regCapAppDesc'        Root='HKLM' Key='Software\bloom\Capabilities'                                    Name='ApplicationDescription' Type='string' Value='A hardware accelerated image viewer'/>
                            <!-- Common -->
                            <RegistryValue Id='regCapJpg'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.jpg'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapJpeg'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.jpeg'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPng'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.png'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapApng'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.apng'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapGif'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.gif'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapBmp'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.bmp'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapWebp'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.webp'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapTif'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.tif'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapTiff'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.tiff'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapIco'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ico'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPbm'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.pbm'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPgm'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.pgm'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPpm'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ppm'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapTga'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.tga'   Type='string' Value='bloom.AssocFile'/>
                            <!-- Modern -->
                            <RegistryValue Id='regCapAvif'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.avif'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapJxl'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.jxl'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapHeic'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.heic'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapHeif'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.heif'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapQoi'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.qoi'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapJp2'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.jp2'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapJ2k'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.j2k'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapJ2c'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.j2c'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapJpx'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.jpx'   Type='string' Value='bloom.AssocFile'/>
                            <!-- Specialty -->
                            <RegistryValue Id='regCapHdr'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.hdr'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapExr'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.exr'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPsd'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.psd'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPsb'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.psb'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapSvg'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.svg'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapSvgz'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.svgz'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapIcns'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.icns'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapDds'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.dds'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapFf'     Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ff'    Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapKra'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.kra'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapXcf'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.xcf'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapDcm'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.dcm'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapDicom'  Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.dicom' Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapKtx2'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ktx2'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapFits'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.fits'  Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapFit'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.fit'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapFts'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.fts'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapEps'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.eps'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPs'     Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ps'    Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapEpsf'   Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.epsf'  Type='string' Value='bloom.AssocFile'/>
                            <!-- RAW -->
                            <RegistryValue Id='regCap3fr'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.3fr'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapAri'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ari'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapArw'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.arw'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapCr2'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.cr2'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapCr3'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.cr3'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapCrm'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.crm'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapCrw'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.crw'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapDcr'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.dcr'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapDcs'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.dcs'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapDng'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.dng'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapErf'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.erf'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapFff'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.fff'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapIiq'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.iiq'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapKdc'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.kdc'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapMef'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.mef'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapMos'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.mos'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapMrw'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.mrw'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapNef'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.nef'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapNrw'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.nrw'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapOrf'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.orf'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapOri'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.ori'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapPef'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.pef'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapQtk'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.qtk'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapRaf'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.raf'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapRaw'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.raw'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapRw2'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.rw2'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapRwl'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.rwl'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapSrw'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.srw'   Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regCapX3f'    Root='HKLM' Key='Software\bloom\Capabilities\FileAssociations' Name='.x3f'   Type='string' Value='bloom.AssocFile'/>
                        </Component>

                        <!-- Common formats: jpg, jpeg, png, gif, bmp, webp, tif, tiff, ico, apng, pbm, pgm, ppm, tga -->
                        <Component Id='AssocCommon' Guid='*'>
                            <RegistryValue Id='regExtJpg'      Root='HKLM' Key='Software\Classes\.jpg'                                           Type='string' Value='bloom.AssocFile' KeyPath='yes'/>
                            <RegistryValue Id='regExtJpgOwp'   Root='HKLM' Key='Software\Classes\.jpg\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtJpeg'     Root='HKLM' Key='Software\Classes\.jpeg'                                          Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtJpegOwp'  Root='HKLM' Key='Software\Classes\.jpeg\OpenWithProgids'  Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtPng'      Root='HKLM' Key='Software\Classes\.png'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtPngOwp'   Root='HKLM' Key='Software\Classes\.png\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtApng'     Root='HKLM' Key='Software\Classes\.apng'                                          Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtApngOwp'  Root='HKLM' Key='Software\Classes\.apng\OpenWithProgids'  Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtGif'      Root='HKLM' Key='Software\Classes\.gif'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtGifOwp'   Root='HKLM' Key='Software\Classes\.gif\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtBmp'      Root='HKLM' Key='Software\Classes\.bmp'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtBmpOwp'   Root='HKLM' Key='Software\Classes\.bmp\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtWebp'     Root='HKLM' Key='Software\Classes\.webp'                                          Type='string' Value='bloom.AssocFile'/>
