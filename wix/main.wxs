            </Directory>

            <Directory Id='ProgramMenuFolder'>
                <Directory Id='ApplicationProgramsFolder' Name='bloom'>
                    <Component Id='ApplicationShortcut' Guid='*'>
                        <Shortcut
                            Id='ApplicationStartMenuShortcut'
                            Name='bloom'
                            Description='Image Viewer'
                            Target='[Bin]\bloom.exe'
                            WorkingDirectory='Bin'
                            Icon='ProductICO'/>
                        <RemoveFolder Id='CleanUpShortcut' On='uninstall'/>
                        <RegistryValue Id='regShortcut' Root='HKCU' Key='Software\bloom' Name='installed' Type='integer' Value='1' KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs all binaries.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            <ComponentRef Id='binary0'/>
            <ComponentRef Id='AssocHandler'/>
            <ComponentRef Id='AppCapabilities'/>
            <ComponentRef Id='ApplicationShortcut'/>

            <Feature
                Id='FileAssociations'
                Title='File Associations'
                Description='Register bloom as a handler for image files.'
                Level='1'
                AllowAdvertise='no'
                Display='expand'
                Absent='allow'>
                <Feature
                    Id='AssocCommonFeature'
                    Title='Common formats (jpg, png, gif, bmp, webp, tif, ico, apng, tga, pbm, pgm, ppm)'
                    Description='Associate bloom with common image formats: JPEG, PNG, GIF, BMP, WebP, TIFF, ICO, APNG, TGA, and Netpbm formats.'
                    Level='1'
                    AllowAdvertise='no'
                    Absent='allow'>
                    <ComponentRef Id='AssocCommon'/>
                </Feature>
                <Feature
                    Id='AssocModernFeature'
                    Title='Modern formats (avif, jxl, heic, heif, qoi, jp2, j2k)'
                    Description='Associate bloom with modern image formats: AVIF, JPEG XL, HEIC, HEIF, QOI, and JPEG 2000.'
                    Level='0'
                    AllowAdvertise='no'
                    Absent='allow'>
                    <ComponentRef Id='AssocModern'/>
                </Feature>
                <Feature
                    Id='AssocSpecialtyFeature'
                    Title='Specialty formats (hdr, exr, psd, svg, icns, dds, kra, xcf, dcm, eps, ...)'
                    Description='Associate bloom with specialty formats: HDR, OpenEXR, PSD, PSB, SVG, ICNS, DDS, Krita, GIMP XCF, DICOM, FITS, EPS, and more.'
                    Level='0'
                    AllowAdvertise='no'
                    Absent='allow'>
                    <ComponentRef Id='AssocSpecialty'/>
                </Feature>
                <Feature
                    Id='AssocRawFeature'
                    Title='RAW camera formats (arw, cr2, nef, dng, ...)'
                    Description='Associate bloom with RAW camera formats from Canon, Nikon, Sony, Fuji, and others.'
                    Level='0'
                    AllowAdvertise='no'
                    Absent='allow'>
                    <ComponentRef Id='AssocRaw'/>
                </Feature>
            </Feature>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location of the [ProductName] executable to the PATH system environment variable.'
                Level='0'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <!-- Notify the shell to refresh file association icons/defaults -->
        <CustomAction Id='NotifyShell' Directory='TARGETDIR' ExeCommand='[SystemFolder]cmd.exe /c ie4uinit.exe -show' Execute='deferred' Return='ignore' Impersonate='yes'/>
        <!-- Launch bloom after install completes (controlled by LAUNCHAPP property) -->
        <CustomAction Id='LaunchApplication' FileKey='exe0' Execute='immediate' Return='asyncNoWait'/>

        <InstallExecuteSequence>
            <Custom Action='NotifyShell' Before='InstallFinalize'>NOT Installed</Custom>
        </InstallExecuteSequence>

        <UI>
            <UIRef Id='WixUI_InstallDir'/>
            <Publish Dialog='ExitDialog' Control='Finish' Event='DoAction' Value='LaunchApplication'>LAUNCHAPP=1</Publish>
        </UI>

    </Product>

</Wix>
