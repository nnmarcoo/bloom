                        </Component>

                        <!-- Modern formats: avif, jxl, heic, heif, qoi, jp2, j2k, j2c, jpx -->
                        <Component Id='AssocModern' Guid='*'>
                            <RegistryValue Id='regExtAvif'     Root='HKLM' Key='Software\Classes\.avif'                                          Type='string' Value='bloom.AssocFile' KeyPath='yes'/>
