                            <RegistryValue Id='regExtIco'      Root='HKLM' Key='Software\Classes\.ico'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtIcoOwp'   Root='HKLM' Key='Software\Classes\.ico\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtPbm'      Root='HKLM' Key='Software\Classes\.pbm'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtPbmOwp'   Root='HKLM' Key='Software\Classes\.pbm\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtPgm'      Root='HKLM' Key='Software\Classes\.pgm'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtPgmOwp'   Root='HKLM' Key='Software\Classes\.pgm\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
                            <RegistryValue Id='regExtPpm'      Root='HKLM' Key='Software\Classes\.ppm'                                           Type='string' Value='bloom.AssocFile'/>
                            <RegistryValue Id='regExtPpmOwp'   Root='HKLM' Key='Software\Classes\.ppm\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
