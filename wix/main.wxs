                        <!-- Specialty formats: hdr, exr, psd, psb, svg, svgz, icns, dds, ff, kra, xcf, dcm, dicom, ktx2, fits, fit, fts, eps, ps, epsf -->
                        <Component Id='AssocSpecialty' Guid='*'>
                            <RegistryValue Id='regExtHdr'      Root='HKLM' Key='Software\Classes\.hdr'                                           Type='string' Value='bloom.AssocFile' KeyPath='yes'/>
                            <RegistryValue Id='regExtHdrOwp'   Root='HKLM' Key='Software\Classes\.hdr\OpenWithProgids'   Name='bloom.AssocFile'   Type='string' Value=''/>
